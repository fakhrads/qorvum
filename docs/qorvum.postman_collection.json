{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-4a5b-8c9d-0e1f2a3b4c5d",
		"name": "Qorvum Ledger API",
		"description": "Collection for Qorvum Post-Quantum Blockchain API Gateway.\n\n## Auto-Login\nPre-request script otomatis login sebelum request ke endpoint protected.\nAtur `username` dan `password` di collection variables, lalu langsung hit endpoint manapun.\n\n## Authentication\n- Production: Bearer token via PQ-MSP (`QorvumToken`)\n- Dev mode (tanpa CA): gunakan header `X-Identity` + `X-Roles` (ada di tiap request, disabled by default)\n\n## WebSocket (Real-time Stream)\nKoneksi: `ws://localhost:8080/api/v1/ws?token={{token}}`\nTopik: `blocks`, `tx`, `node_status`, `heartbeat`\n\n## Base URL\n`http://localhost:8080/api/v1`",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// ── Qorvum Auto-Login ────────────────────────────────────────────────────",
					"// Skip untuk endpoint public agar tidak infinite loop",
					"const url = pm.request.url.toString();",
					"const skipPaths = ['/auth/login', '/auth/bootstrap', '/health', '/stats'];",
					"if (skipPaths.some(p => url.includes(p))) return;",
					"",
					"// Cek apakah token masih valid (buffer 60 detik)",
					"const token  = pm.collectionVariables.get('token');",
					"const expiry = parseInt(pm.collectionVariables.get('tokenExpiry') || '0');",
					"const now    = Math.floor(Date.now() / 1000);",
					"if (token && expiry > now + 60) return;",
					"",
					"// Token tidak ada / expired → auto-login",
					"const baseUrl  = pm.collectionVariables.get('baseUrl');",
					"const username = pm.collectionVariables.get('username');",
					"const password = pm.collectionVariables.get('password');",
					"",
					"if (!username || !password) {",
					"    console.warn('[Qorvum] Set collection variables `username` and `password` to enable auto-login.');",
					"    return;",
					"}",
					"",
					"pm.sendRequest({",
					"    url:    baseUrl + '/auth/login',",
					"    method: 'POST',",
					"    header: [{ key: 'Content-Type', value: 'application/json' }],",
					"    body: {",
					"        mode: 'raw',",
					"        raw: JSON.stringify({ username: username, password: password })",
					"    }",
					"}, function(err, res) {",
					"    if (err) {",
					"        console.error('[Qorvum] Auto-login error:', err);",
					"        return;",
					"    }",
					"    const data = res.json();",
					"    if (data.success && data.data && data.data.token) {",
					"        pm.collectionVariables.set('token',       data.data.token);",
					"        pm.collectionVariables.set('tokenExpiry', String(data.data.expires_at));",
					"        console.log('[Qorvum] Auto-login OK — token valid until',",
					"            new Date(data.data.expires_at * 1000).toISOString());",
					"    } else {",
					"        console.error('[Qorvum] Auto-login failed:', JSON.stringify(data));",
					"    }",
					"});"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [""]
			}
		}
	],
